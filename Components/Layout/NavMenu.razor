@using Microsoft.AspNetCore.Components.Routing

<div class="sidebar bg-dark text-white vh-100 p-3">

    <!-- Logo -->
    <div class="navbar-brand mb-4 d-flex align-items-center">
        <img src="images/logo.png" alt="Logo" height="40" />
        <span class="ms-2">My Portfolio</span>
    </div>

    <!-- Navigation -->
    <ul class="nav flex-column">
        <li class="nav-item mb-2">
            <NavLink class="nav-link text-white" href="/" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill me-2"></span> Home
            </NavLink>
        </li>
        <li class="nav-item mb-2">
            <NavLink class="nav-link text-white" href="about">
                <span class="oi oi-person me-2"></span> About
            </NavLink>
        </li>
        <li class="nav-item mb-2">
            <NavLink class="nav-link text-white" href="projects">
                <span class="oi oi-folder me-2"></span> Projects
            </NavLink>
        </li>
        <li class="nav-item mb-2">
            <NavLink class="nav-link text-white" href="contact">
                <span class="oi oi-envelope-closed me-2"></span> Contact
            </NavLink>
        </li>
    </ul>
</div>